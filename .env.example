# Copy this file to .env and adjust values as needed.
# .env is gitignored — never commit it.

# Server
HOST=0.0.0.0
PORT=1337

# Ollama API
OLLAMA_BASE_URL=http://localhost:11434

# Models
# Image generation model — must be an Ollama-compatible diffusion model you have pulled (must be pulled via ollama pull)
IMAGE_MODEL=x/z-image-turbo
# Fallback image model used automatically when IMAGE_MODEL fails (leave blank to disable)
IMAGE_MODEL_FALLBACK=x/flux2-klein

# Prompt optimization model (must be pulled via ollama pull)
PROMPT_MODEL=llama3.2

# Google Drive (optional): OAuth “Web” client — sign in once via footer “Connect Google Drive”
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
# PUBLIC_BASE_URL=http://127.0.0.1:1337
# (Redirect URI in Cloud Console: {PUBLIC_BASE_URL}/api/auth/google/callback)
# Target folder: either a path (folders created if needed) or a single folder ID from Drive URL
# GOOGLE_DRIVE_FOLDER_PATH=bal/new
# GOOGLE_DRIVE_FOLDER_ID=
