# Copy this file to .env and adjust values as needed.
# .env is gitignored — never commit it.

# Server
HOST=0.0.0.0
PORT=1337

# Ollama API
OLLAMA_BASE_URL=http://localhost:11434

# Models
# Image generation model — must be an Ollama-compatible diffusion model you have pulled (must be pulled via ollama pull)
IMAGE_MODEL=x/z-image-turbo
# Fallback image model used automatically when IMAGE_MODEL fails (leave blank to disable)
IMAGE_MODEL_FALLBACK=x/flux2-klein

# Prompt optimization model (must be pulled via ollama pull)
PROMPT_MODEL=llama3.2
