# Copy this file to .env and adjust values as needed.
# .env is gitignored — never commit it.

# Server
HOST=0.0.0.0
PORT=1337

# Ollama API
OLLAMA_BASE_URL=http://localhost:11434

# Models
# Image generation model — must be an Ollama-compatible diffusion model you have pulled (must be pulled via ollama pull)
IMAGE_MODEL=x/z-image-turbo

# Prompt optimization model (must be pulled via ollama pull)
PROMPT_MODEL=llama3.2
